{
  "name": "label-printer-cloud-customer-pairing",
  "version": "1.0.0",
  "description": "Customer pairing Lambda for the DM Label Printer customer-facing web app at app.label.ninja - exposes /api/v1/pairing/codes (device-side) and /api/v1/pairing/claim (web-side) over Function URLs.",
  "main": "dist/handlers/pairing-codes.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build",
    "test": "npm run build && node --test dist/test/smoke.test.js",
    "prepackage": "npm run rebuild",
    "deploy:prod": "npm run rebuild && lambda-upload deploy-prod dm",
    "deploy:prod:check": "lambda-upload deploy-prod dm --check --force --assume-runtime nodejs24.x",
    "deploy:prod:upgrade": "npm run rebuild && lambda-upload deploy-prod dm --upgrade-config"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmngr/label-printer-cloud-customer-pairing.git"
  },
  "keywords": [
    "label-printer",
    "lambda",
    "pairing",
    "customer-pairing",
    "dynamodb"
  ],
  "author": "",
  "license": "ISC",
